def init():

    return

def solve():
    init()

    n, k = map(int, input().split())
    lst = []

    for i in range(n):
        x = int(input())
        lst.append(x)

    pre = [0]
    for elm in lst:
        pre.append(pre[-1] + elm)

    ans = 0
    for i in range(k, n+1):
        ans = max(ans, pre[i] - pre[i-k])
    print(ans)

    return

solve()
