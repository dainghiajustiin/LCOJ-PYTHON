import sys

TASK = "subseq"
sys.stdin = open(TASK + ".inp", "r")
sys.stdout = open(TASK + ".out", "w")

def init():

    return

def solve():
    init()

    dataInput = map(int, sys.stdin.read().split())

    nSize = next(dataInput)
    ans = 10**18
    S = 0

    for i in range(1, nSize + 1):
        nums = next(dataInput)
        if(S + nums <= 0): S += nums
        else: S = 0 
        ans = min(ans, S)

    print(ans)

    return

solve()
