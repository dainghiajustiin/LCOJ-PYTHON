import sys

def pw(a: int, b: int) -> int:
    if(b == 0): return 1
    if(b == 1): return a 
    if(b == 2): return a**2 % 10
    if(b & 1): return a * pw(pw(a, b >> 1), 2) % 10 
    return pw(pw(a, b >> 1), 2) % 10

def init():

    return

def solve():
    init()

    a, b = [int(x) for x in input().split()]
    print(pw(a % 10, b))

    return

solve()
