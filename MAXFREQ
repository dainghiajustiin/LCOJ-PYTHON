def init():

    return

def solve():
    init()

    n = int(input())
    lst = list(map(int, input().split()))
    cnt = [0] * (10**5+7)
    cntMax = 0

    for elm in lst:
        cnt[elm] += 1
        cntMax = max(cntMax, cnt[elm])

    for i in range(n):
        if(cntMax == cnt[lst[i]]):
            print(lst[i], cntMax)
            return

    return

solve()
