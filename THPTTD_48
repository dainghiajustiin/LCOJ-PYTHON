import sys
from array import array 

TASK = "pair"
sys.stdin = open(TASK + ".inp", "r")
sys.stdout = open(TASK + ".out", "w")

N, K = map(int, input().split())
lp = array('i', [0] * (N + 1)) 
pr = []
ans = 0 

for i in range(2, N + 1):
    if(lp[i] == 0):
        lp[i] = i 
        pr.append(i)

    for j in pr:
        if(i*j > N): break 
        lp[i*j] = j 
        if(j == lp[i]): break 

for i in range(2, N + 1 - K):
    if(lp[i] == i and lp[i + K] == i + K): ans += 1 

print(ans)
