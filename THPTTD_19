import sys

TASK = "demuoc"
sys.stdin = open(TASK + ".inp", "r")
sys.stdout = open(TASK + ".out", "w")

N = int(input())
cnt = [0] * (N + 1)
cnt[1] = 1
ans = 0

for i in range(2, N + 1):
    for j in range(i, N + 1, i):
        cnt[j] += 1 

for i in range(N + 1):
    if(cnt[i] > cnt[ans]): ans = i 

print(ans)
