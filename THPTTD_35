import sys

TASK = "zero"
sys.stdin = open(TASK + ".inp", "r")
sys.stdout = open(TASK + ".out", "w")

n = int(input())
lst = list(map(int, input().split()))
dct = {0 : 1}
ans = 0
S = 0

for elm in lst:
    S += elm 
    if(S in dct): 
        ans += dct[S]
        dct[S] += 1 
    else:
        dct.update({S : 1})

print(ans)
    
