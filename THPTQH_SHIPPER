import sys

TASK = "SHIPPER"
sys.stdin = open(TASK + ".inp", "r")
sys.stdout = open(TASK + ".out", "w")

dataInput = sys.stdin.read().split()
N, M = int(dataInput[0]), int(dataInput[1])
lst = [int(dataInput[i]) for i in range(2, N + 2)]
dct = {}
ans = 0

for elm in lst:
    if(elm in dct): dct[elm] += 1
    else: dct.update({elm : 1})

for elm in dct:
    if(dct[elm] <= M): ans = max(ans, dct[elm])

print(ans)
