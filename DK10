month, year = list(map(int, input().split()))

if(not(1 <= month and month <= 12) or year <= 0):
    print("INVALID")
else:
    if((month <= 7 and month % 2 == 1) or (month > 7 and month % 2 == 0)):
        print(31)
    elif(month == 2):
        if((year % 4 == 0 and year % 100 != 0) or year % 400 == 0):
            print(29)
        else:
            print(28)
    else:
        print(30)
