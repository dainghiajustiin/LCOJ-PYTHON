import sys
import os
from array import array

def init():

    return

def solve():
    init()

    def getInput():
        for chunk in sys.stdin.buffer:
            num = 0
            has_num = False
            for byte in chunk:
                if(byte >= 48):
                    num = num * 10 + (byte - 48)
                    has_num = True 
                else:
                    if(has_num):
                        yield num 
                        num = 0
                        has_num = False
            if has_num:
                yield num
                num = 0
                has_num = False

    dataInput = getInput()

    n = next(dataInput)
    K = next(dataInput)
    lst = array('i', dataInput)

    ans = 0
    left = 0

    for right in range(n):
        while(lst[right] - lst[left] > K): left += 1
        if(right - left + 1 > ans): ans = right - left + 1

    sys.stdout.write(str(ans))

    return

solve()
