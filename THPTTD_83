import sys

TASK = "cachnhiet"
sys.stdin = open(TASK + ".inp", "r")
sys.stdout = open(TASK + ".out", "w")

dataInput = sys.stdin.read().split()
N = int(dataInput[0])
lst = [int(dataInput[i]) for i in range(1, N + 1)]
lst.sort()
newlst = [] 
i = N - 1
cnt = 0
ans = 0
while(cnt < N):
    cnt += 1
    newlst.append(lst[i])
    ans += newlst[-1]
    if(len(newlst) > 1): ans += max(0, newlst[-2] - newlst[-1])
    
    i = N - i - 1 
    if(cnt & 1 == 0): i -= 1

print(ans)
