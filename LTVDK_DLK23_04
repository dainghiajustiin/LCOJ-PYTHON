import sys

def init():

    return

def solve():
    init()

    n = int(input())
    lst = list(map(int, input().split()))
    cnt = [0] * 5
    ans = 0

    for elm in lst:
        cnt[elm] += 1
    
    ans = cnt[4]
    ans += cnt[3]
    cnt[1] = max(0, cnt[1] - cnt[3])

    ans += cnt[2]//2
    if(cnt[2] % 2 != 0):
        ans += 1
        cnt[1] = max(0, cnt[1] - 2)
    
    if(cnt[1] > 0):
        ans += cnt[1]//4 + (1 if cnt[1] % 4 != 0 else 0)

    print(ans)

    return

solve()
