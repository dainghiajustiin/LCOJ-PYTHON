import sys

n = int(input())
isFirst = True

for i in range(2, int(n**0.5 + 1)):
    if(n % i == 0):
        while(n % i == 0):
            if(isFirst == False): print("*", end = "")
            else: isFirst = False
            print(i, end = "")
            n //= i

if(n > 1):
    if(isFirst == False): print("*", end = "")
    print(n)
