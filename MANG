def init():

    return

def solve():
    init()

    n = int(input())
    lst = list(map(int, input().split()))

    sum = 0
    cnt = 0
    positive = 0

    for i in range(n):
        sum += lst[i]
        if(lst[i] % 2 == 0): cnt += 1
        if(lst[i] > 0): positive = lst[i]

    print(sum, end=" ")
    print(cnt, end=" ")
    print(positive, end=" ")

    return

solve()
