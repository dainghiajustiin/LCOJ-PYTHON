def init():

    return

def solve():
    init()

    n = int(input())
    lst = list(map(int, input().split()))
    s = 0
    pre = 0
    ans = 10**18
    
    for elm in lst:
        s += elm 
    
    for i in range(len(lst)):
        pre += lst[i]
        ans = min(ans, abs(2*pre - s))
    
    print(ans)

    return

solve()
