TASK = "duongdi"
FILE_INPUT = TASK + ".inp"
FILE_OUTPUT = TASK + ".OUT"

dp = [[0] * 1010 for i in range(1010)]

with open(FILE_INPUT, 'r') as fileIn, open(FILE_OUTPUT, 'w') as fileOut:
    n = int(fileIn.readline())
    
    dp[0][1] = 1
    pre = 0
    cur = 1
    for i in range(1, n+1):
        for j in range(1, n+1):
            dp[cur][j] = dp[pre][j] + dp[cur][j-1]
        pre = 1 - pre 
        cur = 1 - cur
    
    fileOut.write(str(dp[pre][n]))
