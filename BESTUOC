import sys

def gcd(a: int, b: int) -> int:
    while(b > 0):
        a, b = b, a%b 
    return a 

n = int(input())
lst = list(map(int, input().split()))
pre = [0] * (n + 2)
suf = [0] * (n + 2)

for i in range(1, n + 1):
    pre[i] = gcd(pre[i-1], lst[i-1])

for i in range(n, 0, -1):
    suf[i] = gcd(suf[i+1], lst[i-1])

ans = 0
for i in range(1, n + 1):
    ans = max(ans, gcd(pre[i-1], suf[i+1]))
print(ans)
