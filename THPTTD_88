import sys

TASK = "bai1"
sys.stdin = open(TASK + ".inp", "r")
sys.stdout = open(TASK + ".out", "w")

dataInput = sys.stdin.read().split()
N = int(dataInput[0])
lst = [int(dataInput[i]) for i in range(1, N + 1)]

def beautyNumber(S: str) -> bool:
    for i in range(1, len(S)):
        if(S[i] < S[i-1]): return False 
    return True 

for i in range(N):
    for j in range(i + 1, N):
        if(beautyNumber(str(lst[i] + lst[j]))):
            print(1)
            sys.exit() 

print(0)
